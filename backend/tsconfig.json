{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "sourceMap": true,

    "types": ["node"]
  },

  "include": ["src/**/*", "prisma/seed.ts", "server.ts"],
  "exclude": ["node_modules", "dist"]
}
